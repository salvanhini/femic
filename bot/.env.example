# Preencha com os dados do seu projeto Supabase.
# Em bot servidor, use a SERVICE ROLE KEY para acessar appointments/patients sem erro de RLS.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-aqui

# Alternativa compatível com o padrão antigo do projeto:
# FEMIC_SUPABASE_URL=https://seu-projeto.supabase.co
# FEMIC_SUPABASE_SERVICE_ROLE_KEY=cole-a-service-role-key-aqui

WHATSAPP_SERVICE_NAME=baileys-main
# Use qr para escanear pelo log. Use pairing apenas se quiser código por telefone.
WHATSAPP_LOGIN_METHOD=qr
# Opcional com WHATSAPP_LOGIN_METHOD=pairing: coloque o número com DDI/DDD.
# Exemplo: WHATSAPP_PAIRING_PHONE=5516999999999
WHATSAPP_PAIRING_PHONE=
HOURS_BEFORE=12
CHECK_INTERVAL_MINUTES=5
HEARTBEAT_INTERVAL_SECONDS=60
CLINIC_TIME_ZONE=America/Sao_Paulo
REMINDER_TOLERANCE_MINUTES=30
