FEMIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
FEMIC_SUPABASE_SERVICE_ROLE_KEY=COLE_A_SERVICE_ROLE_KEY_NO_PAINEL_DA_DISCLOUD
FEMIC_BAILEYS_SERVICE_NAME=baileys-main
FEMIC_BAILEYS_SESSION_DIR=.session
FEMIC_BAILEYS_POLL_MS=60000
FEMIC_BAILEYS_LOG_LEVEL=info
# Opcional: atraso antes das respostas do bot para parecer mais natural.
FEMIC_BAILEYS_REPLY_DELAY_MIN_MS=1800
FEMIC_BAILEYS_REPLY_DELAY_MAX_MS=4200
# Opcional: use para gerar codigo de pareamento sem depender do QR no log.
# Exemplo: FEMIC_BAILEYS_PAIRING_PHONE=5516999999999
FEMIC_BAILEYS_PAIRING_PHONE=
# Opcional: numero que recebe aviso quando o bot conectar/reconectar.
FEMIC_BAILEYS_ADMIN_PHONE=
# Opcional, mas recomendado para conversa natural do bot.
FEMIC_GROQ_API_KEY=
FEMIC_GROQ_MODEL=llama-3.3-70b-versatile
# Endereço e mapa da clínica (usado nas mensagens de confirmação)
FEMIC_CLINIC_ADDRESS=Rua Dr. Cristiano Infante Vieira, 560, Pq Laranjeiras, Araraquara-SP
FEMIC_CLINIC_MAPS_URL=https://share.google/xHA1PkuiVG0iCNfBQ
# URL da página pública de agendamento (enviada pelo bot para pacientes novos)
FEMIC_SCHEDULING_URL=https://femic.com.br/agendar
